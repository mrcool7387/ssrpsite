[[include component:image-block
|name= https://upload.wikimedia.org/wikipedia/commons/b/b7/Overview_of_soccer_field_near_Veleslav%C3%ADnova_street_in_Jarom%C4%9B%C5%99ice_nad_Rokytnou%2C_T%C5%99eb%C3%AD%C4%8D_District.jpg
