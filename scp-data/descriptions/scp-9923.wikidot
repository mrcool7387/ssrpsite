[[module css]]

/* == FADE AWAY == */
 #u-fade-away {
    /* Mouse Hover Reveals Rating Module */
    opacity: calc(1 / 3);
    transition: all .25s ease-in-out;
}
 #u-fade-away:hover {
    opacity: 1;
}

:root {
    --logo: url(https://scp-wiki.wdfiles.com/local--files/scp-9923/surrealistics-blue.png);
    --title: "R\0026 C SITE-⌘";
    --subtitle: "MEDIUM INFORMATICS";
    --w-gold: 229, 214, 157;
}

.ego {
    color: #AD4DBF;
}

.superego {
    color: #c66d00;
}

.id {
    color: #bf4d73;
}

.other {
    color: #75bf4d;
}

.blur{
    filter: blur(4px);
}

.titled {
  color: rgb(var(--basalt-bright-element-color));
  text-decoration: underline 3px;
  text-underline-offset: 3px;
}

.widetable :is(table:not(.form), table.wiki-content-table) {
    width: 100% !important;
    margin-top: 1.2rem;
    margin-bottom: 1rem;
}

.acstable :is(table:not(.form), table.wiki-content-table) {
    font-size: 0.9em;
}

:is(#page-content table:not(.form), table.wiki-content-table) th :is(div.blockquote, blockquote) {
    padding-block: 1rem;
    font-family: var(--UI-font);
    font-size: 1.05em;
    font-weight: normal;
    text-align: left;
    word-spacing: 1px;
}

div.surr_memo {
    --memo-heading: "NOTICE FROM THE DEPARTMENT OF SURREALISTICS";
}

div.rss_memo {
    --memo-heading: "RESEARCH STATION SYNECDOCHE MEMOSPORE";
}

div.infotech_memo {
    --memo-heading: "NOTICE FROM THE DEPARTMENT OF INFORMATION TECHNOLOGY";
}

div.underwatch_memo {
    --memo-heading: "UNDERWATCH COMMAND COMMUNIQUÉ";
}

#page-content .anom-bar-container.vessel .text-part .disrupt-class::before {
content: "V" !important;
}

#page-content .anom-bar-container.enochian .text-part .disrupt-class::before {
content: "E" !important;
}

#page-content .anom-bar-container.quintessent .text-part .risk-class::before {
content: "5" !important;
}

#page-content .anom-bar-container.digitized .text-part .risk-class::before {
content: "5" !important;
}

/*---- keyframes ----*/

@keyframes pulse {
    from { box-shadow: 0px 0px 0.5rem rgb(var(--w-gold)); }
    to { box-shadow: 0px 0px 1.8rem rgb(var(--w-gold)); }
}

@keyframes glow {
    from { filter: blur(2px); }
    to { filter: blur(8px)}
}

@keyframes text-glow {
    from { text-shadow: 0 0 2px currentcolor; }
    to { text-shadow: 0 0 8px currentcolor; }
}

/* ----custom class---- */

.text-glow {
    animation: text-glow 3s 0s ease-out infinite alternate;
}

