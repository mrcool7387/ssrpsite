[[module CSS]]
@import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400..900&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Yuji+Boku&display=swap');

#page-content div:is(.document) {
    max-width: 45rem;
}

div:is(.document) {
    display: block;
    margin-inline: auto;
    margin-block: 1.5em;
    padding: 1.5rem;
    position: relative;
/*    --posX: -20vw;*/
}

div.document {
    background-color: rgb(253, 253, 253);
    box-shadow: 0px 1px 1.9px -4px rgba(0, 0, 0, 0.1), 0px 6px 15px -4px rgba(0, 0, 0, 0.2);
    color: rgb(50, 50, 53);
}

div:is(.document)::before, div:is(.document)::after {
    content: "";
    height: 98%;
    position: absolute;
    width: 98%;
    z-index: -1;
}

div:is(.document)::before {
    left: -5px;
    top: 4px;
    transform: rotate(-2.5deg);
}

div:is(.document)::after {
    right: -3px;
    top: 1px;
    transform: rotate(1.4deg);
}

div:is(.document)::before, div:is(.document)::after {
    background-color: rgb(253, 253, 253);
}

div.document::before {
    box-shadow: 0px 1px 1.9px -4px rgba(0, 0, 0, 0.1), 0px 6px 15px -4px rgba(0, 0, 0, 0.1);
}

div.document::after {
    box-shadow: 0px 1px 1.9px -4px rgba(0, 0, 0, 0.1), 0px 6px 15px -4px rgba(0, 0, 0, 0.05);
}

@media only screen and (max-width: 1020px) {
    div:is(.document)::before, div:is(.document)::after {
        display: none;
    }
}

table.wiki-content-table {
    margin: 0.5em 0;
}

.hospital table.wiki-content-table th {
    background-color: rgb(26, 42, 74) !important;
    color: #fff !important;
    font-weight: 700 !important;
}

.hospital table.wiki-content-table td {
    text-decoration: underline dotted rgba(0, 0, 0, 0.2);
    font-family: "Yuji Boku", serif;
    font-weight: 400;
    font-style: normal;
    font-size: 80%;
}

.hospital table.wiki-content-table th, .hospital table.wiki-content-table td {
    border-color: rgb(132, 150, 176) !important;
}

.hospital hr {
    background-color: rgb(26, 42, 74) !important;
}

.hospital h3 {
    color: rgb(26, 42, 74) !important;
}

.biblical{
    font-family: "Cinzel Decorative", serif;
    font-weight: 400;
    font-style: normal;
}

.clasificado {
    background: rgb(0,0,0) !important;
    color: rgb(0,0,0) !important;
}
[[/module]]
