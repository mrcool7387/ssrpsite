:root {

/* Change the desktop top-left sidebar square background */
#main-content a[href="#sidebar"],
#menu-button,
.side-bar,
.open-menu a {
    background-color: #000000 !important;
    border: 1px solid #1e1c1e !important;
}

/* Change the 3 menu lines inside it to Dark Ink */
#main-content a[href="#sidebar"]::before,
#main-content a[href="#sidebar"]::after,
#main-content a[href="#sidebar"] span,
#menu-button::before,
#menu-button::after,
#menu-button span,
.side-bar::before,
.side-bar::after,
.side-bar span,
.open-menu a::before,
.open-menu a::after,
.open-menu a span {
    background-color: #03a9fc !important;
}

/* Optional: Invert colors when your cursor hovers over it */
#main-content a[href="#sidebar"]:hover,
#menu-button:hover,
.side-bar:hover,
.open-menu a:hover {
    background-color: #1e1c1e !important;
}
#main-content a[href="#sidebar"]:hover::before,
#main-content a[href="#sidebar"]:hover::after,
#menu-button:hover::before,
#menu-button:hover::after,
.open-menu a:hover::before,
.open-menu a:hover::after {
    background-color: #f2b818 !important;
}
[[/module]]

[[module CSS]]

/* Change the main container box background and border */
div.page-rate-widget-box, 
div.rate-box-with-credit-button {
    background-color: #000000 !important;
    border: 1px solid #4a4a4a !important;
}

/* Force the inner elements (points and buttons) to have a transparent background */
div.page-rate-widget-box span.rate-points,
div.page-rate-widget-box span.rateup,
div.page-rate-widget-box span.ratedown,
div.page-rate-widget-box span.cancel {
    background-color: transparent !important;

}

/* Text color of the rating numbers and signs (+ / -) */
div.page-rate-widget-box span.rate-points,
div.page-rate-widget-box span.rateup a,
div.page-rate-widget-box span.ratedown a,
div.page-rate-widget-box span.cancel a {
    color: #C3C3C3 !important;
}

/* Text hover color when mousing over buttons */
div.page-rate-widget-box span.rateup a:hover,
div.page-rate-widget-box span.ratedown a:hover,
div.page-rate-widget-box span.cancel a:hover {
    color: #ffffff !important;
    background-color: transparent !important; /* Keeps hover from adding an unwanted background */

}
/* TARGET THE INNER WHITE CITATION BOX */
.licensebox .code {
    background-color: #f2b818 !important; /* Warning Yellow background */
    color: #1e1c1e !important;            /* Dark ink text color */
    border: 1px dashed #1e1c1e !important; /* Matches the dashed border to the text */
}

/* Fix text and labels sitting inside that specific yellow block */
.licensebox .code * {
    color: #1e1c1e !important;
}
[[/module]]


