[[module css]]
:root {
  --header-title: "ORGANIZATION";
  --header-subtitle: "ENSURE ● INCLUDE ● PRESERVE";
  --logo-img: url(https://scp-wiki.wdfiles.com/local--files/calibri-s-mega-cool-art-page-it-s-mostly-just-icons-but-what/Volatility);

  --head-font: var(--ui-font);

  --accentLite: 230, 40, 60;
  --posX: calc(50% - 333px - 17.5rem);
}

#page-content h1, h2, h3, h4, h5, h6 {
  font-weight: 900;
}

#page-content > p {
  font-weight: normal;
}

#page-content .blockquote {
  margin: 1em 2em;
}

#page-content hr {
  height: 1px;
  background-color: rgb(var(--accent));
  margin-top: 1.5em;
  margin-bottom: 1.5em;
}

#page-content .notation {
  width: auto;
  margin: auto;
  border-left: solid 4px rgba(var(--accent), 0.33);
  border-right: solid 4px rgba(var(--accent), 0.33);
}

#page-content .jotting {
  padding: 0.5em 1.5em;
}

.notation > .jotting,
#page-content > .jotting > blockquote,
#page-content > .jotting tr td {
  background: white;
}

#page-content a {
  font-weight: bold;
}

#page-content tr th {
  background: #eee;
}

.fncon {
  font-family: var(--page-font) !important;
  border-color: rgb(var(--accent));
  background-color: #eee;
}

.fncon::before {
  background-color: rgb(var(--accent));
}

@media only screen and (min-width: 1278px) {
  .fncon {
    width: 14rem;
    border: none;
    border-left: 5px rgb(var(--accent)) solid;
  }

  .fncon::before {
    top: 14px; left: -10px;
  }
}

@media (max-width: 767px) {
  .jotting,
  .modal {
    margin: 0.5em;
  }   
}

#page-content .scp-image-block img {
  border: solid 1px rgba(var(--accent), 0.66);
}

#page-content .scp-image-block.block-left {
  margin: 0.5em 1.5em 1em 0em;
}

#page-content .scp-image-block.block-right {
  margin: 0.5em 0em 1em 1.5em;
}

#page-content .scp-image-caption {
  border: solid 1px rgba(var(--accent), 0.66);
  border-radius: 0px;
  margin-top: 7px;
}

:is(.anom-bar-container, .anom-bar-esoteric) + :not(.acs-extra),
.acs-extra + * {
    margin-top: 1.2rem !important;
}

#breadcrumbs, .pseudocrumbs {
  font-size: 90%;
}

.bblock:hover {
  color: white;
}
[[/module]]

=====
