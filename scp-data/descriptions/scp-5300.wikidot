[!-- Remove the page title, add email formatting. --]
[[module CSS]]
#page-title {
    display: none;
}

.logbox {
    display: inline-block;
    float: top;
    padding: 1px 15px;
    -moz-box-sizing: border-box;
    -webkit-box-sizing: border-box;
    -ms-box-sizing: border-box;
    box-sizing: border-box;
    width:100%;
    margin: auto;
    border: solid 2px #000000;
    box-shadow: 0 1px 3px rgba(0,0,0,.5);
}
.tofrom {
    margin-left: 10px;
    margin-top: 5px;
    padding: 1px 15px;
    border-left: solid 3px maroon;
}
[[/module]]

[!-- The content for some of these ListPages is pretty minimal. This outer div acts as a container which allows us to put the footer-wikiwalk-nav element at the bottom of the article. --]
[[div style="position: relative; height:100%"]]

[!-- I don't like the standard layout of the info bar, so here's some hacky shit to make it do what I want without copying all the CSS. --]
[[include :scp-wiki:component:info-ayers-source | comments=[!--]]
